{
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "index.html",
        "admin.html",
        "aviso-legal.html",
        "politica-de-cookies.html",
        "politica-de-privacidad.html",
        "terminos-y-condiciones.html",
        "styles.css",
        "admin.css",
        "legal.css",
        "script.js",
        "admin.js",
        "robots.txt",
        "sitemap.xml",
        "assets/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/favicon.ico",
      "destination": "/assets/favicon.svg"
    },
    {
      "source": "/favicon.png",
      "destination": "/assets/favicon.svg"
    },
    {
      "source": "/politica-de-privacidad",
      "destination": "/politica-de-privacidad.html"
    },
    {
      "source": "/aviso-legal",
      "destination": "/aviso-legal.html"
    },
    {
      "source": "/politica-de-cookies",
      "destination": "/politica-de-cookies.html"
    },
    {
      "source": "/terminos-y-condiciones",
      "destination": "/terminos-y-condiciones.html"
    }
  ]
}
