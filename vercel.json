{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin",
      "dest": "/api/index.js"
    },
    {
      "src": "/politica-de-privacidad",
      "dest": "/api/index.js"
    },
    {
      "src": "/aviso-legal",
      "dest": "/api/index.js"
    },
    {
      "src": "/politica-de-cookies",
      "dest": "/api/index.js"
    },
    {
      "src": "/terminos-y-condiciones",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
